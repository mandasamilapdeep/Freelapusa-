{% style %}
  .choose_your_main-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}
<div class="choose_your_main choose_your_main-{{ section.id }}">
  <div class="container">
    <div class="title_box">
      {% if collection.metafields.custom.choose_your != blank %}
        <h2 class="built_titling h1">{{ collection.metafields.custom.choose_your }}</h2>
      {% endif %}
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Choose your",
  "limit": 1,
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Padding top",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Padding bottom",
      "default": 50
    }
  ],
  "presets": [
    {
      "name": "Choose your"
    }
  ]
}
{% endschema %}
