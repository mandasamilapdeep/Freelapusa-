<div id="section-id-{{ section.id }}" class="{% if section.settings.color_scheme != 'default' %}use-color-scheme use-color-scheme--{{ section.settings.color_scheme }} fully-padded-row--medium{% else %}fully-spaced-row--medium{% endif %}">
  {%- style -%}
    #section-id-{{ section.id }} .logo-list__logo-image {
      opacity: {{ section.settings.image_opacity }}%;
    }
    #section-id-{{ section.id }} .logo-list__link:hover .logo-list__logo-image {
      opacity: {{ section.settings.image_opacity | times: 1.2 | at_most: 100 }}%;
    }
    {%- for block in section.blocks -%}
      #section-id-{{ section.id }} .logo-list__logo-{{ forloop.index }} {
        --logo-max-width: {{ block.settings.image_width }}px;
      }
    {%- endfor -%}
  {%- endstyle -%}

  {%- capture logos_html -%}
    {%- for block in section.blocks -%}
      {%- liquid
        assign animation_delay = forloop.index | times: 0.15 | append: 's'
        assign animation_attrs = 'data-cc-animate data-cc-animate-delay="' | append: animation_delay | append: '"'
      -%}
      <div class="logo-list__logo logo-list__logo-{{ forloop.index }}{% if section.settings.layout == 'carousel' %} slider__item{% elsif section.settings.layout == 'scrolling' %} marquee-item{% endif %}">
        {%- if block.settings.link != blank -%}
          <a class="logo-list__link fade-in-up" href="{{ block.settings.link }}" {{ block.shopify_attributes }} {%- render 'animation-attrs', attrs: animation_attrs -%}>
        {%- else -%}
          <div class="fade-in-up" {{ block.shopify_attributes }} {%- render 'animation-attrs', attrs: animation_attrs -%}>
        {%- endif -%}

          <div class="logo-list__logo-image">
            {%- if block.settings.image != blank -%}
              {%- liquid
                assign image_sizes = block.settings.image_width | append: 'px'
                assign image_widths = block.settings.image_width | times: 2 | prepend: ', ' | prepend: block.settings.image_width
                render 'image' with block.settings.image, sizes: image_sizes, widths: image_widths
              -%}
            {%- else -%}
              <div class="placeholder-image">
                {{- 'logo' | placeholder_svg_tag: 'placeholder-svg' -}}
              </div>
            {%- endif -%}
          </div>

          {%- if block.settings.title != blank -%}
            <div class="logo-list__logo-title">
              {{ block.settings.title | escape }}
            </div>
          {%- endif -%}

        {%- unless block.settings.link != blank -%}
          </div>
        {%- else -%}
          </a>
        {%- endunless -%}
      </div>
    {%- endfor -%}

    {% if section.blocks.size == 0 %}
      {%- for i in (1..4) -%}
        <div class="logo-list__logo">
          <div class="logo-list__logo-image">
            <div class="placeholder-image">
              {{- 'logo' | placeholder_svg_tag: 'placeholder-svg' -}}
            </div>
          </div>
        </div>
      {%- endfor -%}
    {% endif %}
  {%- endcapture -%}

  <div class="{% if section.settings.layout != 'scrolling' or section.settings.full_width == false %}container{% endif %}">
    {%- if section.settings.layout == 'carousel'-%}
      <carousel-slider class="carousel block collection-slider">
        <div class="hometitle align-center has-paging slider-nav" {%- render 'animation-attrs', attrs: 'data-cc-animate data-cc-animate-delay="0.15s"' -%}>
          <button name="prev" class="slider-nav__btn has-ltr-icon">
            <span class="visually-hidden">{{ 'general.slider.previous' | t }}</span>
            {% render 'icon-chevron-left' %}
          </button>
          <h2 class="has-paging__title h4 m-0{% if section.settings.show_title == false %} visually-hidden{% endif %}">
            {{- section.settings.title | escape -}}
          </h2>
          <button name="next" class="slider-nav__btn has-ltr-icon">
            <span class="visually-hidden">{{ 'general.slider.next' | t }}</span>
            {% render 'icon-chevron-right' %}
          </button>
        </div>
        <div class="logo-list-container slider slider--mobile-container-pad slider--no-scrollbar">
          <div class="logo-list logo-list--count-{{ section.blocks.size }} {{ section.settings.alignment }} slider__grid">
            {{- logos_html -}}
          </div>
        </div>
      </carousel-slider>
    {%- elsif section.settings.layout == 'scrolling' -%}
      <div class="hometitle align-center{% if section.settings.show_title == false %} visually-hidden{% endif %}" {%- render 'animation-attrs', attrs: 'data-cc-animate data-cc-animate-delay="0.15s"' -%}>
        <h2 class="h4 m-0">
          {{- section.settings.title | escape -}}
        </h2>
      </div>

      <script src="{{ 'scrolling-banner.js' | asset_url }}" defer></script>
      <scrolling-banner class="block">
        <div class="marquee-container">
          <div class="logo-list marquee marquee--{{ section.settings.scroll_direction }}" style="--duration: {{ 42 | minus: section.settings.scroll_speed }}s; --space: 0px;" role="marquee">
            {%- for i in (1..15) -%}
            <span class="marquee-content {{ section.settings.alignment }}{% if logos_html contains '</a>' %} marquee-content--contains-link{% endif %}"{% unless forloop.first %} aria-hidden="true"{% endunless %}>
              {%- if forloop.first -%}
                {{ logos_html }}
              {%- else -%}
                {{ logos_html | replace: '<a ', '<a tabindex="-1" ' }}
              {%- endif -%}
            </span>
          {%- endfor -%}

          </div>
        </div>
      </scrolling-banner>
    {%- else -%}
      <div class="hometitle align-center{% if section.settings.show_title == false %} visually-hidden{% endif %}" {%- render 'animation-attrs', attrs: 'data-cc-animate data-cc-animate-delay="0.15s"' -%}>
        <h2 class="h4 m-0">
          {{- section.settings.title | escape -}}
        </h2>
      </div>
      <div class="logo-list-container">
        <div class="logo-list logo-list--count-{{ section.blocks.size }} {{ section.settings.alignment }}">
          {{- logos_html -}}
        </div>
      </div>
    {%- endif -%}
  </div>
</div>


{% schema %}
{
  "name": "Logo list",
  "class": "section-logo-list",
  "disabled_on": {
    "groups": [
      "aside"
    ]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Logo list"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show heading",
      "info": "If not visible, heading is still used for accessibility & SEO",
      "default": true
    },
    {
      "type": "radio",
      "id": "layout",
      "label": "Layout",
      "default": "grid",
      "options": [
        {
          "value": "grid",
          "label": "Grid"
        },
        {
          "value": "carousel",
          "label": "Carousel"
        },
        {
          "value": "scrolling",
          "label": "Scrolling banner"
        }
      ]
    },
    {
      "visible_if": "{{ section.settings.layout == 'scrolling' }}",
      "id": "full_width",
      "type": "checkbox",
      "label": "Full page width",
      "default": true
    },
    {
      "visible_if": "{{ section.settings.layout == 'scrolling' }}",
      "type": "range",
      "id": "scroll_speed",
      "min": 0.5,
      "max": 40,
      "step": 0.5,
      "unit": "x",
      "label": "Scroll speed",
      "default": 1
    },
    {
      "visible_if": "{{ section.settings.layout == 'scrolling' }}",
      "type": "select",
      "id": "scroll_direction",
      "label": "Scroll direction",
      "options": [
        {
          "label": "Left to right",
          "value": "right"
        },
        {
          "label": "Right to left",
          "value": "left"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Logo alignment",
      "default": "items-center",
      "options": [
        {
          "value": "items-start",
          "label": "Top"
        },
        {
          "value": "items-center",
          "label": "Middle"
        },
        {
          "value": "items-end",
          "label": "Bottom"
        }
      ]
    },
    {
      "type": "range",
      "id": "image_opacity",
      "label": "Logo opacity",
      "min": 20,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 75
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "default",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "range",
          "id": "image_width",
          "label": "Logo width",
          "min": 40,
          "max": 280,
          "step": 10,
          "unit": "px",
          "default": 180
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "info": "Optional"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logo list",
      "category": "Feature",
      "settings": {
      }
    }
  ]
}
{% endschema %}
