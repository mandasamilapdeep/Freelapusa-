{% style %}

.custom-text-blocks .section-heading {
  text-align: center;
  font-size: 50px;
  line-height: 1;
  margin-bottom: 45px;
  letter-spacing: 1px;
}

.custom-text-blocks .blocks-wrapper:not(.slick-slider) {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 35px;
}

.text-card_custom_outer {
    padding: 0 22px;
}
.blocks-wrapper.slick-initialized.slick-slider {
    margin-left: -22px;
    margin-right: -22px;
}
.custom-text-blocks .text-card_custom {
    border: 2px solid #222;
    padding: 70px 40px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    min-height: 370px;
}

.custom-text-blocks .small-heading {
    font-size: 16px;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin: 0 0 10px;
    position: relative;
    display: inline-block;
    padding-bottom: 8px;
}

.custom-text-blocks .small-heading:after {
  content: "";
  position: absolute;
  left: 0;
  bottom: 0;
  width: 120px;
  height: 2px;
  background: #f1d400;
}

.custom-text-blocks .card-title {
    font-size: 50px;
    overflow-wrap: break-word;
    word-wrap: break-word;
    word-break: break-word;
}


@media screen and (max-width: 991px) {
  .custom-text-blocks .blocks-wrapper {
    grid-template-columns: repeat(2, 1fr);
  }

  .custom-text-blocks .card-title {
    font-size: 42px;
  }
}

@media screen and (max-width: 768px) {
  .custom-text-blocks {
    padding: 0px 0px 50px;
  }

  .custom-text-blocks .blocks-wrapper {
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .custom-text-blocks .section-heading {
    font-size: 34px;
    margin-bottom: 35px;
  }

  .custom-text-blocks .text-card {
    min-height: auto;
    padding: 35px 25px;
  }

  .custom-text-blocks .card-title {
    font-size: 34px;
  }

  .custom-text-blocks .card-description {
    font-size: 17px;
  }
  .blocks-wrapper.slick-initialized.slick-slider {
      margin-left: 0;
      margin-right: 0;
  }
  .text-card_custom_outer {
      padding: 0;
  }
  .custom-text-blocks .text-card_custom {
      min-height: auto;
      padding: 40px 15px;
  }

}
{% endstyle %}
<section class="custom-text-blocks" style="background: {{ section.settings.bg_color }};">
  <div class="container">
    
    {% if section.settings.heading != blank %}
      <h2 class="section-heading built_titling">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    <div id="blocks-wrapper_{{ section.id }}" class="blocks-wrapper">
      {% for block in section.blocks %}
        <div class="text-card_custom_outer">
        <div class="text-card_custom" {{ block.shopify_attributes }}>
          
          {% if block.settings.small_heading != blank %}
            <p class="small-heading">
              {{ block.settings.small_heading }}
            </p>
          {% endif %}

          {% if block.settings.title != blank %}
            <h3 class="card-title built_titling">
              {{ block.settings.title }}
            </h3>
          {% endif %}

          {% if block.settings.description != blank %}
            <div class="card-description">
              {{ block.settings.description }}
            </div>
          {% endif %}

        </div>
      </div>
      {% endfor %}
    </div>

  </div>
</section>
<script>
document.addEventListener("DOMContentLoaded", function () {
    $('#blocks-wrapper_{{ section.id }}').slick({
        slidesToShow: 3,
        slidesToScroll: 1,
        arrows: false,
        dots: false,
        infinite: false,
        speed: 600,
        prevArrow: '<button type="button" class="slick-prev"><i class="fa-solid fa-arrow-down"></i></button>',
        nextArrow: '<button type="button" class="slick-next"><i class="fa-solid fa-arrow-down"></i></button>',
        responsive: [
            {
                breakpoint: 1201,
                settings: {
                    slidesToShow: 2,
                    dots: true
                }
            },
            {
                breakpoint: 768,
                settings: {
                    slidesToShow: 1,
                    dots: true
                }
            }
        ]
    });
  });
</script>

{% schema %}
{
  "name": "Custom text blocks",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "ACCURATE TIMING MADE EASY"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f5f5f5"
    }
  ],
  "blocks": [
    {
      "type": "text_block",
      "name": "Text Block",
      "settings": [
        {
          "type": "text",
          "id": "small_heading",
          "label": "Small Heading",
          "default": "STOPWATCH"
        },
        {
          "type": "html",
          "id": "title",
          "label": "Main Title",
          "default": "FAST BUT INCONSISTENT"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Human reaction time limits trust in small improvements."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom text blocks",
      "blocks": [
        {
          "type": "text_block"
        },
        {
          "type": "text_block"
        },
        {
          "type": "text_block"
        }
      ]
    }
  ]
}
{% endschema %}