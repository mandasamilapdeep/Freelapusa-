<link rel="stylesheet" href="{{ 'collapsible-tabs.css' | asset_url }}" {%- render 'lazy-stylesheet-attrs' %}>
<div class="container" {%- render 'animation-attrs', attrs: 'data-cc-animate' -%}>
  <div class="collapsible-tabs custom">
    {% if section.settings.title != blank %}
      <h3
        class="h1 collapsible-tabs__heading collapsible-tabs__content built_titling"
        id="faq-{{ section.settings.title | handle }}"
      >
        {{ section.settings.title | escape }}
      </h3>
    {% endif %}

    {%- for faq in collection.metafields.custom.collection_collapsible_tabs_question.value -%}
      <div class="collapsible-tabs__block" {{ block.shopify_attributes }}>
        <div class="collapsible-tabs__tab">
          <details-disclosure>
            <details
              class="disclosure"
            >
              <summary class="disclosure__title">
                <div class="disclosure__title_inner">
                  {{- faq.question -}}
                </div>
              </summary>
              <div class="disclosure__panel has-motion">
                <div class="disclosure__content rte">
                  {{- faq.answer | metafield_tag -}}
                </div>
              </div>
            </details>
          </details-disclosure>
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

{% if section.settings.enable_faq_schema %}
  <script type="application/ld+json">
    {%- capture faq_json -%}
      {%- for faq in collection.metafields.custom.collection_collapsible_tabs_question.value -%}
        {%- if faq.question != blank  and faq.answer != blank -%}
          {
            "@type": "Question",
            "name": {{ faq.question | json }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ faq.answer | json }}
            }
          },
        {%- endif -%}
      {%- endfor -%}
    {%- endcapture -%}

    {%- if faq_json != blank -%}
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {{ faq_json | remove_last: ',' }}
      ]
    }
    {%- endif -%}
  </script>
{% endif %}

{% schema %}
{
  "name": "Collect collapsible tabs",
  "class": "section-collapsible-tabs",
  "disabled_on": {
    "groups": ["aside"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Collapsible tabs"
    },
    {
      "type": "checkbox",
      "id": "open_tab",
      "label": "Open by default",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_faq_schema",
      "label": "Enable FAQ structured data",
      "info": "Adds FAQPage data to the page for SEO",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Collection collapsible tabs",
      "category": "Info",
      "settings": {}
    }
  ]
}
{% endschema %}
