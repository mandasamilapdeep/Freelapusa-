{% style %}
  .breadcrumbs-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
  }
{% endstyle %}

<div
  class="container"
  {%- render 'animation-attrs', attrs: 'data-cc-animate data-cc-animate-delay="0.2s"' -%}
>
  <div
    class="page-header built_titling breadcrumbs-section-{{ section.id }}"
    data-dynamic-product-content="breadcrumbs"
  >
    {% render 'breadcrumbs', show_next_prev: true %}
  </div>
</div>
{% schema %}
{
  "name": "breadcrumbs",
  "limit": 1,
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Padding top",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Padding bottom",
      "default": 50
    }
  ],
  "presets": [
    {
      "name": "breadcrumbs"
    }
  ]
}
{% endschema %}
